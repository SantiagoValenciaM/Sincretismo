[gd_scene load_steps=1 format=3]

[ext_resource type="Script" path="res://scripts/ui/game_over.gd" id="1_script"]

[node name="GameOver" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.05, 0.02, 0.02, 0.92)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -100.0
offset_right = 200.0
offset_bottom = 100.0
grow_horizontal = 2
grow_vertical = 2
alignment = 1
theme_override_constants/separation = 24

[node name="TitleLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "El pueblo no duerme..."
horizontal_alignment = 1
theme_override_font_sizes/font_size = 32
theme_override_colors/font_color = Color(0.8, 0.1, 0.1, 1)

[node name="BtnReiniciar" type="Button" parent="VBox"]
layout_mode = 2
text = "Continuar la promesa"
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.98, 0.655, 0, 1)

[node name="BtnMenu" type="Button" parent="VBox"]
layout_mode = 2
text = "Volver al inicio"
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.98, 0.655, 0, 0.7)

[connection signal="pressed" from="VBox/BtnReiniciar" to="." method="_on_btn_reiniciar_pressed"]
[connection signal="pressed" from="VBox/BtnMenu" to="." method="_on_btn_menu_pressed"]
